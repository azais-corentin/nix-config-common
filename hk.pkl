amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Builtins.pkl"

local preCommitSteps = new Mapping<String, Step> {
  ["dprint"] = Builtins.dprint
  ["gitleaks"] {
    check = "gitleaks git --pre-commit --redact --staged --verbose"
  }
  ["pkl"] = Builtins.pkl
}

hooks {
  ["pre-commit"] {
    fix = false
    stash = "git"
    steps = preCommitSteps
  }
  ["commit-msg"] {
    steps {
      ["commitlint"] {
        check = "mise run commitlint {{commit_msg_file}}"
      }
    }
  }
  // ["fix"] {
  //     fix = true
  //     steps = linters
  // }
  // ["check"] {
  //     steps = linters
  // }
}
